# Public DNS name that points to your server.
APP_DOMAIN=chat.example.com

# Use local for a single VPS. Switch to kafka or rabbitmq only when you run multiple app instances.
APP_MESSAGING_PROVIDER=local

# Demo mode. For real users, migrate to oauth2 and wire a real IdP.
APP_SECURITY_MODE=dev
APP_SECURITY_ALLOW_HEADER_IMPERSONATION=false

# Database credentials.
POSTGRES_DB=chatapp
POSTGRES_USER=chat
POSTGRES_PASSWORD=change-this-strong-password

# RabbitMQ credentials (used when APP_MESSAGING_PROVIDER=rabbitmq).
RABBITMQ_DEFAULT_USER=chat
RABBITMQ_DEFAULT_PASS=change-this-rabbit-password
